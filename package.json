{
  "name": "coding-agent",
  "version": "0.1.0",
  "description": "CLI coding agent",
  "license": "MIT",
  "type": "module",
  "bin": {
    "coding-agent": "./dist/cli/main.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli/main.ts",
    "smoke:inspect": "npm run build && node scripts/smoke-noninteractive.mjs inspect",
    "smoke:pause-resume": "npm run build && node scripts/smoke-noninteractive.mjs pause-resume",
    "smoke:write": "npm run build && node scripts/smoke-noninteractive.mjs write",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "ink": "^6.8.0",
    "react": "^19.2.4",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/react": "^19.2.14",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
